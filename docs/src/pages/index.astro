---
import { Font } from "astro:assets";
import Seo from "../components/Seo.astro";
import "../styles/global.css";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/wrec.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <Seo
      title="wrec"
      description="The efficient, agent-native screen recorder for macOS."
    />
    <Font cssVariable="--font-departure" preload />
    <script defer src="https://assets.onedollarstats.com/stonks.js"></script>
    <title>wrec</title>
  </head>
  <body class="m-0 overflow-hidden select-none">
    <main class="home-red" aria-label="wrec">
      <header class="home-bar">
        <span>
          made by&nbsp;<a
            href="https://shivam.ing"
            target="_blank"
            rel="noopener noreferrer">shivam</a
          >
        </span>
        <span class="home-bar-links">
          <a href="/benchmarks">benchmarks</a>
          <a href="/docs">docs</a>
        </span>
      </header>
      <div class="home-logo" aria-hidden="true">wrec</div>
    </main>
  </body>
</html>

<style>
  .home-red {
    position: fixed;
    inset: 0;
    display: flex;
    flex-direction: column;
    padding: 0 16px;
    box-sizing: border-box;
    background: var(--wrec-red);
    font-family: var(--font-departure), monospace;
  }

  .home-bar-links {
    display: inline-flex;
    gap: 18px;
  }

  .home-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    max-width: 1000px;
    margin: 0 auto;
    padding: 5px 0 4px;
    font-size: 0.875rem;
    color: #fff;
  }

  .home-bar a {
    color: #fff;
    text-decoration: none;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
    font-weight: 600;
  }

  .home-bar a:hover,
  .home-bar a:focus-visible {
    text-decoration: underline;
  }

  .home-logo {
    flex: 1;
    min-height: 0;
    width: 100%;
    max-width: 1000px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-departure), monospace;
    font-size: clamp(3rem, 8vw, 6rem);
    font-weight: 700;
    line-height: 1;
    color: #0d0d0d;
  }
</style>
