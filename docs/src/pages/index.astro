---
import { Font } from "astro:assets";
import Seo from "../components/Seo.astro";
import "../styles/global.css";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/wrec.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <Seo
      title="wrec"
      description="The efficient, agent-native screen recorder for macOS."
    />
    <Font cssVariable="--font-departure" preload />
    <script defer src="https://assets.onedollarstats.com/stonks.js"></script>
    <title>wrec</title>
  </head>
  <body class="m-0 overflow-hidden select-none">
    <main class="home-red" aria-label="wrec">
      <header class="home-bar">
        <div class="home-identity">
          <span>
            made by&nbsp;<a
              href="https://shivam.ing"
              target="_blank"
              rel="noopener noreferrer">shivam</a
            >
          </span>
          <span class="home-wordmark">wrec</span>
        </div>
        <nav class="home-bar-links" aria-label="Primary">
          <a href="/benchmarks">benchmarks</a>
          <a href="/docs">docs</a>
        </nav>
      </header>
    </main>
  </body>
</html>

<style>
  .home-red {
    position: fixed;
    inset: 0;
    padding: 0 16px;
    box-sizing: border-box;
    background: var(--wrec-red);
    font-family: var(--font-departure), monospace;
  }

  .home-bar {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    width: 100%;
    max-width: 1000px;
    margin: 0 auto;
    padding: 18px 0 16px;
    font-size: 14px;
    color: #fff;
  }

  .home-identity {
    line-height: 1;
  }

  .home-wordmark {
    display: block;
    margin-top: 6px;
    color: #fff;
    font-size: inherit;
    font-weight: 700;
    line-height: 1;
  }

  .home-bar-links {
    display: inline-flex;
    gap: 18px;
  }

  .home-bar a {
    color: #fff;
    text-decoration: none;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
    font-weight: 600;
  }

  .home-bar a:hover,
  .home-bar a:focus-visible {
    text-decoration: underline;
  }
</style>
